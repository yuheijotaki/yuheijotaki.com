---
import '@/styles/globals.scss';
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';
import {
  buildBlogPostingJsonLd,
  buildBreadcrumbJsonLd,
  buildWebsiteJsonLd,
} from '@/utils/jsonLd';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: {
    title: string;
    publishedTime: Date;
    modifiedTime?: Date;
  };
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = '/og.jpg',
  article,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.url).toString();
const isRootPage = Astro.url.pathname === '/';

const jsonLdItems = [
  article &&
    buildBlogPostingJsonLd({
      title,
      description,
      imageURL,
      canonicalURL: canonicalURL.toString(),
      publishedTime: article.publishedTime,
      modifiedTime: article.modifiedTime,
    }),
  article && buildBreadcrumbJsonLd(article.title),
  isRootPage && buildWebsiteJsonLd(),
].filter(Boolean);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light dark" />
<meta name="theme-color" content="#fffcf0" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#1c1a1a" media="(prefers-color-scheme: dark)" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="Feed" href="/feed.xml" />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:locale" content="ja_JP" />
{
  article && (
    <>
      <meta property="article:published_time" content={article.publishedTime.toISOString()} />
      {article.modifiedTime && (
        <meta property="article:modified_time" content={article.modifiedTime.toISOString()} />
      )}
      <meta property="article:author" content={SITE_TITLE} />
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

{
  jsonLdItems.map((item) => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} is:inline />
  ))
}
